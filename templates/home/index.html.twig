{% extends "base.html.twig" %}
{% block body %}
	<!-- ======= Hero Slider Section ======= -->
	<section id="hero-slider" class="hero-slider">
		<div class="container" data-aos="fade-up">
			<div class="section-header d-flex justify-content-between align-items-center mb-5">
				<h2 id="quisommesnous">Qui-sommes-nous?</h2>
				<div>
					<a href="category.html" class="more">{{parametres['Accueil: présentation de PicBleu à droite']|raw}}</a>
				</div>
			</div>
			{{parametres['Accueil: présentation de PicBleu']|raw}}
		</div>
		<div class="container-md" data-aos="fade-in">
			<div class="row">
				<div class="col-12" style="height:300px;">
					<div class="swiper  sliderFeaturedPosts" data-controller="carousel" data-carousel-options-value='{"direction": "horizontal","navigation": {"nextEl": ".custom-swiper-button-next","prevEl": ".custom-swiper-button-prev"}}'>
						<div class="swiper-wrapper">
							{% for item in carousels %}
								<div class="swiper-slide">
									<a data-action="click->swiper#open" data-background="{{asset(item.image)|imagine_filter('bandeaufixe')}}" class="swiper-lazy img-bg d-flex align-items-end" style="background-image: url('{{asset(item.image)|imagine_filter('lazy')}}')">
										<div class="img-bg-inner">
											<h2>{{item.titre|raw}}</h2>
											<p class="h4">{{item.texte|raw}}</p>
										</div>
										<div class="swiper-lazy-preloader"></div>
									</a>
								</div>
							{% endfor %}
						</div>
						<div class="custom-swiper-button-next">
							<span class="bi-chevron-right"></span>
						</div>
						<div class="custom-swiper-button-prev">
							<span class="bi-chevron-left"></span>
						</div>
						<div class="swiper-pagination"></div>
					</div>
				</div>
			</div>
		</div>
	</section>
	<!-- End Hero Slider Section -->

	<!-- ======= Encyclopédie Section ======= -->
	<section id="article" class="posts">
		<div class="container" data-aos="fade-up">
			<div class="section-header d-flex justify-content-between align-items-center mb-5">
				<h2>Nos articles</h2>
				<div>
					<a href="category.html" class="more">Voir tous les articles</a>
				</div>
			</div>
			<div class="row g-5">
				<div class="col-lg-4">
					<div class="post-entry-1 lg">
						{% if  article['dernier'].image %}
							<a href="single-post.html"><img src="{{asset(article['dernier'].image)}}" alt="" class="img-fluid " data-controller="apparaitre" data-apparaitre-class-value="shadow-drop-bl"></a>
						{% endif %}
						<div class="post-meta">
							<span class="date">{{article['dernier'].getCategoriesjoin}}</span>
							<span>{{(article['dernier'].updatedAt?article['dernier'].updatedAt:article['dernier'].createdAt)|date('d/m à H:i', "Europe/Paris")}}</span>
						</div>
						<h2>
							<a href="single-post.html">{{article['dernier'].titre|raw}}</a>
						</h2>
						<p class="mb-4 d-block">{{TBckintro(article['dernier'].article)}}</p>
						<div class="d-flex align-items-right author">
							<button class="btn btn-primary col">Lire l'article</button>
						</div>

					</div>

				</div>

				<div class="col-lg-8">
					<div class="row g-5">
						<div class="col-lg-8 border-start custom-border ">
							<div class="row">
								{% for item in article['articles']|slice(1) %}
									<div class="post-entry-1 col-6">
										{% if item.image %}
											<a href="single-post.html"><img src="{{asset(item.image)}}" alt="" class="img-fluid"></a>
										{% endif %}
										<div class="post-meta">
											<span class="mx-1">{{item.getCategoriesjoin}}</span>
											<span>{{(item.updatedAt?item.updatedAt:item.createdAt)|date('d/m à H:i', "Europe/Paris")}}</span>
										</div>
										<h2>
											<a href="single-post.html">{{item.titre|raw}}</a>
										</h2>
									</div>
								{% endfor %}
								<div class="d-flex author">
									<button class="btn btn-primary ms-auto">Voir tous les articles</button>
								</div>
							</div>
						</div>

						<!-- Trending Section -->
						<div class="col-lg-4">

							<div class="trending">
								<h3>Article les plus consultés</h3>
								<ul class="trending-post">
									{% for item in article['best']|slice(0,5) %}
										<li>
											<a href="single-post.html">
												<span class="number">{{loop.index}}</span>
												<h3>{{item.titre}}</h3>
												<span class="author float-end">{{(item.updatedAt?item.updatedAt:item.createdAt)|date('d/m à H:i', "Europe/Paris")}}</span>
											</a>
										</li>
									{% endfor %}
								</ul>
							</div>

						</div>
						<!-- End Trending Section -->
					</div>
				</div>

			</div>
			<!-- End .row -->
		</div>
	</section>
	<!-- End Post Grid Section -->

	<!-- ======= Simulateur Section ======= -->
	<section class="category-section">
		<div class="container" data-aos="fade-up">

			<div class="section-header d-flex justify-content-between align-items-center mb-5">
				<h2>Nos simulateurs</h2>
