{% extends "base.html.twig" %}
{% block body %}
	<h5 class="text-center">
		<p>templates/home/index.html.twig</p>
	</h5>
	<h6 class="text-center">test de la présence de twig bundle</h6>
	<p class="text-center">{{TBuploadmax()}}</p>
	<h6 class="text-center">Test de la présence des controllers stimulus de base</h6>
	<p class="text-center">
		<img src="{{asset('/build/avatar.jpg')|imagine_filter('moyen')}}" width="50px" height="50px" data-controller="base--bigpicture">
	</p>
	<p class="text-center">
		Si l'image n'apparait pas, inspecter (chown www-data:)</p>
	<h6 class="text-center">Test de la présence des Services</h6>
	<p class="text-center">
		<u>Test fixtureHelper:</u>
		{{testhelper}}</p>
	<h6 class="text-center">Test Event subscriber (twig global)</h6>
	<p class="text-center">
		<u>Paramètres:</u>
		{{parametres["Mail: Email d'envoie"]|raw}}</p>

{% endblock %}
