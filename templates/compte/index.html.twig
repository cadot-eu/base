{# Here for add your Code #} {# End of your Code #}
{% extends '/admin/base.html.twig' %}
{% set route =path(app.request.attributes.get('_route'),app.request.attributes.get('_route_params'))%}
{% set action =path(app.request.attributes.get('_route'),app.request.attributes.get('_route_params'))| split('/')| last%}
{# Here for add your Code #} {# End of your Code #}

{% block title %}
	Compte
{% endblock %}

{% block body %}

	{# Here for add your Code #} {# End of your Code #}

	{% set choice_isVerified=["<i class=\"bi bi-toggle-off\"><\/i>","<i class=\"bi bi-toggle-on\"><\/i>"] %}

	<h1>Compte</h1>
	{# Here for add your Code #} {# End of your Code #}

	<div>
		<table class="table table-responsive table-striped table-hover align-middle">
			<thead>
				<tr>
					{# Here for add your Code #} {# End of your Code #}

					<th><a class="btn btn-outline-primary {{ app.request.query.get("tri") == "id" ? 'active' }} " href='?tri=id&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>id</a></th>
<th><a class="btn btn-outline-primary {{ app.request.query.get("tri") == "email" ? 'active' }} " href='?tri=email&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>email</a></th>
<th><a class="btn btn-outline-primary {{ app.request.query.get("tri") == "roles" ? 'active' }} " href='?tri=roles&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>roles</a></th>
<th><a class="btn btn-outline-primary {{ app.request.query.get("tri") == "password" ? 'active' }} " href='?tri=password&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>password</a></th>
<th><a class="btn btn-outline-primary {{ app.request.query.get("tri") == "isVerified" ? 'active' }} " href='?tri=isVerified&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>isVerified</a></th>
{%if action=="deleted" %}
    <th>
    <a class="btn btn-outline-primary {{ app.request.query.get(" tri") == 'deletedAt' ? 'active' }} " href='?tri=deletedAt&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>effacé</a>
    </th>
{% endif %}
<th>
    <a class="btn btn-outline-primary {{ app.request.query.get(" tri") == 'createdAt' ? 'active' }} " href='?tri=createdAt&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>créé</a>
</th>
<th>
    <a class="btn btn-outline-primary {{ app.request.query.get(" tri") == 'updatedAt' ? 'active' }} " href='?tri=updatedAt&&ordre={{ app.request.query.get("ordre")=="DESC" ? "ASC":"DESC" }}'>modifié</a>
</th>
					{# Here for add your Code #} {# End of your Code #}

					<th>Actions</th>
				</tr>
			</thead>
			<tbody class="sortable">
				{% for Compte in comptes %}
					{% if true  %}
						<tr
							data-num="{{Compte.id }}">
							{# Here for add your Code #} {# End of your Code #}

							<td class="my-auto " > {{Compte.id}}
</td>
<td class="my-auto " title="{{Compte.email}}"> {{Compte.email|striptags|u.truncate(20, "...")}}
</td>
<td class="my-auto " title="{{Compte.password}}"> {{Compte.password|striptags|u.truncate(20, "...")}}
</td>
<td class="my-auto">
                                {% set retour=0 %}
                                {% for test,value in choice_isVerified %}
                                    {% if test==Compte.isVerified %}
                                        {% set retour=loop.index0 %}
                                    {% endif %}
                                {% endfor %}
                                {% if retour+1==choice_isVerified|length %}
                                    {% set numr=0 %}
                                {% else %}
                                    {% set numr=retour+1 %}
                                {% endif %}
                                <a href="{{path('compte_etat',{'id':Compte.id,'type':'isVerified','valeur':choice_isVerified|keys[numr]})}}" style='font-size:2rem;'  title='{{ choice_isVerified|keys[retour]}}'> {{ choice_isVerified[ choice_isVerified|keys[retour]]|raw}}</a>
</td>
<td>{{ Compte.createdAt is not empty ? Compte.createdAt|date('d/m à H:i', 'Europe/Paris')}}</td>
<td>{{ Compte.updatedAt is not empty ? Compte.updatedAt|date('d/m à H:i', 'Europe/Paris')}}</td>
<td>{{ Compte.deletedAt is not empty ? Compte.deletedAt|date('d/m à H:i', 'Europe/Paris')}}</td>
							{# Here for add your Code #} {# End of your Code #}

							<td>
								{# Here for add your Code #} {# End of your Code #}

								<form method="post" action="{{ path('compte_delete', {'id': Compte.id }) }}" style="margin-block-end: 0;">
									<div
										class="btn-group" role="group" aria-label="actions">
										{# Here for add your Code #} {# End of your Code #}

										<input type="hidden" name="_token" value="{{ csrf_token('delete'~Compte.id ) }}"/>
										<a class='btn btn-xs btn-primary'  title='edit' href="{{ path('compte_edit', {'id': Compte.id }) }}"><i class='icone icone bi bi-pencil-square'></i></a>
										{# Here for add your Code #} {# End of your Code #}

										{% if true %}
											{% if action=='deleted' %}
												{# Here for add your Code #} {# End of your Code #}

												<button class="btn btn-xs btn-warning" title="restaurer" name="delete_restore" value="1">
													<i class="icone bi bi-life-preserver"></i>
												</button>
												<button class="btn btn-xs btn-danger" title="supprimer définitivement" onclick="return confirm('Etes-vous sûr de vouloir effacer cet item?');" name="delete_delete" value="1">
													<i class="icone bi bi-trash"></i>
												</button>
											{% else %}
												{# Here for add your Code #} {# End of your Code #}

												<button class="btn btn-xs btn-warning" title="mettre dans la corbeille" name="delete_softdelete" value="1">
													<i class="icone icone bi bi-trash"></i>
												</button>
											{% endif %}
										{% endif %}

										{# Here for add your Code #} {# End of your Code #}



									</div>
								</form>
								{# Here for add your Code #} {# End of your Code #}

							</td>
						</tr>
					{% endif %}
				{% else %}
					<tr>
						<td colspan="11">Aucun enregistrement</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
	{# Here for add your Code #} {# End of your Code #}

	<div class="row">
		{% if true %}
			<div class="col">
				<a class="btn btn-primary" data-toggle="tooltip" title="ajouter enregistrement" href="{{ path('compte_new') }}">Ajouter un enregistrement</a>
			</div>
		{% endif %}
		{% if true %}
			{% if action=='deleted' %}
				<div class="col-auto">
					<a class="text-muted" href="{{ path('compte_index') }}">voir les enregistrements</a>
				</div>
			{% else %}
				<div class="col-auto">
					<a class="text-muted" href="{{ path('compte_deleted') }}">voir les enregistrements supprimés</a>
				</div>
			{% endif %}
		{% endif %}
	</div>
	{# Here for add your Code #} {# End of your Code #}



	<nav aria-label="Page navigation ">
		<ul
			class="pagination justify-content-center">
			{# precedent #}
			<li class="page-item {{ app.request.query.get('page')==1 or app.request.query.get('page')==0 ? 'disabled' }} ">
				{% if app.request.query.get('page') is defined and app.request.query.get('page')>1 %}
					{% set precedent = app.request.query.get('page') -1 %}
				{% else %}
					{% set precedent = 1 %}
				{% endif %}
				<a class="page-link" href="{{ path('compte_index',{'page':precedent,'tri':app.request.query.get('tri'),'ordre':app.request.query.get('ordre')}) }}">
					<span aria-hidden="true">&laquo;</span>
				</a>
			</li>
			{% if pagesMaxi/10>6 %}
				{# 1 #}
				<li class="page-item">
					<a class="page-link" href="{{ path('compte_index',{'page':1,'tri':app.request.query.get('tri'),'ordre':app.request.query.get('ordre')}) }}">1</a>
				</li>
				{# pages millieu #}
				{% for item in 1..5 %}
					<li class="page-item">
						<a class="page-link " href="{{ path('compte_index',{'page':(pagesMaxi/10/6*loop.index)|number_format(0),'tri':app.request.query.get('tri'),'ordre':app.request.query.get('ordre')}) }}">{{(pagesMaxi/10/6*loop.index)|number_format(0)}}</a>
					</li>
				{% endfor %}
				{# maxi #}
				<li class="page-item">
					<a class="page-link" href={{ path('compte_index',{'page':(pagesMaxi/10)|number_format(0),'tri':app.request.query.get('tri'),'ordre':app.request.query.get('ordre')} ) }}>{{(pagesMaxi/10)|number_format(0)}}</a>
				</li>
			{% else %}
				{% set maxi=(pagesMaxi/10)|number_format(0) %}

				{% for item in 1..(maxi==0?1:maxi) %}
					<li class="page-item">
						<a class="page-link " href="{{ path('compte_index',{'page':loop.index,'tri':app.request.query.get('tri'),'ordre':app.request.query.get('ordre')}) }}">{{loop.index}}</a>
					</li>
				{% endfor %}
			{% endif %}
			{# suivant #}
			<li class="page-item {{ app.request.query.get('page') >= (pagesMaxi/10)|number_format ? 'disabled' }}">
				{% if app.request.query.get('page')==0 %}
					{% set suivant = 2 %}
				{% else %}
					{% set suivant = app.request.query.get('page') +1 %}
				{% endif %}
				<a class="page-link" href="{{ path('compte_index',{'page':suivant,'tri':app.request.query.get('tri'),'ordre':app.request.query.get('ordre')}) }}">
					<span aria-hidden="true">&raquo;</span>
				</a>
			</li>
		</ul>
	</nav>
{%endblock %}
