{# Here for add your Code #} {# End of your Code #}
{% extends '/admin/base.html.twig' %}
{% set route =path(app.request.attributes.get('_route'),app.request.attributes.get('_route_params'))%}
{% set action =path(app.request.attributes.get('_route'),app.request.attributes.get('_route_params'))| split('/')| last%}
{% set current_path = app.request.get('_route') %}
{# Here for add your Code #} {# End of your Code #}

{% block title %}
	Categorie
{% endblock %}

{% block body %}

	{# Here for add your Code #} {# End of your Code #}

	
	<h1>Categorie</h1>
	{# Here for add your Code #} {# End of your Code #}

	<div>
		{{ knp_pagination_filter(pagination, {
                    'r.recherche': 'Recherche',
                }) }}
		{% if pagination.getTotalItemCount>0  %}
			<div>
				{{ pagination.getTotalItemCount }}
				trouvé</div>
		{% endif %}
		<table class="table table-striped table-hover align-middle">
			<thead>
				<tr>
					{# Here for add your Code #} {# End of your Code #}

					<th {% if pagination.isSorted('a.id') %} class='sorted'{% endif %}>
                {{ knp_pagination_sortable(pagination, 'id', 'a.id') }}</th>
<th {% if pagination.isSorted('a.nom') %} class='sorted'{% endif %}>
                {{ knp_pagination_sortable(pagination, 'nom', 'a.nom') }}</th>
					{# Here for add your Code #} {# End of your Code #}

					<th>Actions</th>
				</tr>
			</thead>
			<tbody class="sortable">
				{% for Categorie in pagination %}
					{# Here for add your Code #} {# End of your Code #}

					{% if true  %}
						{# Here for add your Code #} {# End of your Code #}

						<tr
							data-num="{{Categorie.id }}">
							{# Here for add your Code #} {# End of your Code #}

							<td class="my-auto " > {{Categorie.id|raw}}
</td>
<td class="my-auto " title="{{Categorie.nom|striptags|u.truncate(200, '...')}}"> {{Categorie.nom|striptags|u.truncate(40, '...')}}
</td>
<td>{{ Categorie.deletedAt is not empty ? Categorie.deletedAt|date('d/m à H:i', 'Europe/Paris')}}</td>
							{# Here for add your Code #} {# End of your Code #}

							<td>
								{# Here for add your Code #} {# End of your Code #}

								<form method="post" action="{{ path('categorie_delete', {'id': Categorie.id }) }}" style="margin-block-end: 0;">
									<div
										class="btn-group" role="group" aria-label="actions">
										{# Here for add your Code #} {# End of your Code #}

										<input type="hidden" name="_token" value="{{ csrf_token('delete'~Categorie.id ) }}"/>
										<a class='btn btn-xs btn-primary'  title='edit' href="{{ path('categorie_edit', {'id': Categorie.id }) }}"><i class='icone icone bi bi-pencil-square'></i></a>
										{# Here for add your Code #} {# End of your Code #}

										{% if true %}
											{% if action=='deleted' %}
												{# Here for add your Code #} {# End of your Code #}

												<button class="btn btn-xs btn-warning" title="restaurer" name="delete_restore" value="1">
													<i class="icone bi bi-life-preserver"></i>
												</button>
												<button class="btn btn-xs btn-danger" title="supprimer définitivement" onclick="return confirm('Etes-vous sûr de vouloir effacer cet item?');" name="delete_delete" value="1">
													<i class="icone bi bi-trash"></i>
												</button>
											{% else %}
												{# Here for add your Code #} {# End of your Code #}

												<button class="btn btn-xs btn-warning" title="mettre dans la corbeille" name="delete_softdelete" value="1">
													<i class="icone icone bi bi-trash"></i>
												</button>
											{% endif %}
										{% endif %}

										{# Here for add your Code #} {# End of your Code #}



									</div>
								</form>
								{# Here for add your Code #} {# End of your Code #}

							</td>
						</tr>
						{# Here for add your Code #} {# End of your Code #}

					{% endif %}
					{# Here for add your Code #} {# End of your Code #}

				{% else %}
					<tr>
						<td colspan="11">Aucun enregistrement</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
	{# Here for add your Code #} {# End of your Code #}

	<div class="row">
		{% if true %}
			<div class="col">
				<a class="btn btn-primary" data-toggle="tooltip" title="ajouter enregistrement" href="{{ path('categorie_new') }}">Ajouter un enregistrement</a>
			</div>
		{% endif %}
		{% if true %}
			{% if action=='deleted' %}
				<div class="col-auto">
					<a class="text-muted" href="{{ path('categorie_index') }}">voir les enregistrements</a>
				</div>
			{% else %}
				<div class="col-auto">
					<a class="text-muted" href="{{ path('categorie_deleted') }}">voir les enregistrements supprimés</a>
				</div>
			{% endif %}
		{% endif %}
	</div>
	{# Here for add your Code #} {# End of your Code #}

	<div class="row">
		<div class="navigation col-auto mx-auto">
			{{ knp_pagination_render(pagination) }}
		</div>
	</div>

</div>{%endblock %}