{% extends 'base.html.twig' %}

{% block title %}
{{t('Password Reset Email Sent')}}
{% endblock %}

{% block body %}
<div class="col-lg-6 col-12 mx-auto">
    <p>
        {{t('If an account matching your email exists, then an email was just sent that contains a link that you can use to reset your password.
        This link will expire in')}}
        {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
    </p>
    <p>{{t('If you don\'t receive an email please check your spam folder or')}} <a href="{{ path('app_forgot_password_request') }}">{{t('try again')}}</a>.
    </p>
</div>
{% endblock %}